+++ b/Host/Source/LibOpenBLT/port/darwin/xcpprotect.c
@@ -0,0 +1,194 @@
+/************************************************************************************//**
+* \file         port/darwin/xcpprotect.c
+* \brief        XCP Protection module source file.
+* \ingroup      XcpLoader
+* \internal
+*----------------------------------------------------------------------------------------
